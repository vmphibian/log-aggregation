# ansible-lint configuration
# https://ansible.readthedocs.io/projects/lint/configuring/

profile: moderate

# Paths excluded from linting. Molecule playbooks follow different conventions
# (e.g. missing 'name' on plays, tasks in verify.yml that reference dynamic facts)
# and are not subject to the same rules as production Ansible code.
exclude_paths:
  - molecule/

warn_list:
  # role-name: our role is named loki_lab which uses underscores — valid per POSIX
  # but ansible-lint prefers hyphens for galaxy publishing. Since this role is
  # not published to Galaxy, the underscore name is intentional.
  - role-name

# Skip rules that conflict with intentional design decisions
skip_list:
  # Variable names follow the loki_ product prefix convention per the project
  # specification. The loki_lab_ role-prefix requirement conflicts with the
  # deliberately short names documented in the variable reference table.
  # Register variables use _ prefix (e.g. _loki_ready) — internal-only,
  # not part of the public role interface.
  - var-naming[no-role-prefix]
