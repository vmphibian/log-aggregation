---
# yamllint configuration
# https://yamllint.readthedocs.io/en/stable/configuration.html
#
# These settings are kept compatible with ansible-lint's yamllint requirements:
#   comments.min-spaces-from-content: 1
#   braces.max-spaces-inside: 1
#   octal-values.forbid-implicit-octal: true
#   octal-values.forbid-explicit-octal: true

extends: default

rules:
  line-length:
    max: 160
    level: warning

  # Allow both true/false (Ansible convention) and yes/no (YAML default)
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
    level: warning

  # Require document-start marker (---) in all YAML files.
  # ansible-lint enforces this requirement via the yaml[document-start] rule.
  document-start:
    present: true

  # ansible-lint requires at least one space between content and inline comment.
  comments:
    min-spaces-from-content: 1

  # ansible-lint requires max-spaces-inside: 1 for braces.
  braces:
    max-spaces-inside: 1

  # ansible-lint requires implicit and explicit octal values to be forbidden.
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

  comments-indentation: disable
